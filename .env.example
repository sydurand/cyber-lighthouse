# Cyber-Lighthouse Configuration Template
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control

# AI Provider Configuration (choose one)
# Option 1: Google Gemini API (legacy)
# Get a free API key (250 req/day) at: https://ai.google.dev/
# Click "Get API key" → "Create API key in new Google Cloud project"
# No billing required for free tier
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Option 2: OpenRouter API (recommended)
# Get a free API key at: https://openrouter.ai/
# Free models available: meta-llama/llama-3.3-70b-instruct:free, others
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Optional: Database Configuration
DATABASE_FILE=articles.db
JSON_DATABASE_FILE=base_veille.json

# Optional: RSS Feed Configuration
# Customize these if you want to monitor different sources
# BLEEPING_COMPUTER_FEED=https://www.bleepingcomputer.com/feed/
# SANS_ISC_FEED=https://isc.sans.edu/rssfeed_full.xml

# Optional: CISA Known Exploited Vulnerabilities
CISA_KEV_URL=https://www.cisa.gov/cybersecurity-advisories/all.xml

# Optional: API Timeouts (in seconds)
RSS_TIMEOUT=30
GEMINI_TIMEOUT=60

# Optional: Gemini Parameters
GEMINI_TEMPERATURE_REALTIME=0.2
GEMINI_TEMPERATURE_DAILY=0.1

# Optional: CISA Articles to Fetch
CISA_ARTICLE_LIMIT=15

# Optional: Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/cyber_lighthouse.log

# Optional: Retry Settings
MAX_RETRIES=3
RETRY_BACKOFF_FACTOR=2.0

# Optional: Alert Distribution (if using send.py)
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID
# TELEGRAM_BOT_TOKEN=your_bot_token
# TELEGRAM_CHAT_ID=your_chat_id
# TEAMS_WEBHOOK_URL=https://prod-XXX.francecentral.logic.azure.com/workflows/...

# Optional: Semantic Clustering Configuration
# Groups similar articles by topic using AI embeddings
# Lower = more aggressive clustering (0.60-0.65)
# Higher = stricter matching (0.75-0.80)
# Default 0.65 works well for cybersecurity articles
SEMANTIC_SIMILARITY_THRESHOLD=0.65

# Embedding model for semantic clustering (auto-downloaded)
# all-MiniLM-L6-v2: Fast, lightweight (~80MB), good for most use cases
# all-mpnet-base-v2: More accurate but slower and larger
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Optional: HuggingFace Token (for faster model downloads)
# Get a free token at: https://huggingface.co/settings/tokens
# If not set, you'll see a harmless warning about unauthenticated requests
# HF_TOKEN=your_huggingface_token_here

# Suppress HuggingFace warnings (set to 1 to hide unauthenticated request warnings)
HF_HUB_DISABLE_IMPLICIT_TOKEN=1

# Optional: Background Task Scheduler
# REALTIME_INTERVAL: Seconds between RSS feed polls (default: 600 = 10 minutes)
# DAILY_SUMMARY_HOUR: Hour of day (0-23) to generate daily summary (default: 23)
REALTIME_INTERVAL=600
DAILY_SUMMARY_HOUR=23
